# Tab + Leash — environment variables
# Copy to .env.local (never committed). All values must come from real provisioning (Phase 0).

# ── Particle Universal Accounts ──────────────────────────────────────────────
PARTICLE_PROJECT_ID=
PARTICLE_CLIENT_KEY=
PARTICLE_APP_ID=

# ── Magic ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAGIC_PUBLISHABLE_KEY=
MAGIC_SECRET_KEY=

# ── Magic OIDC (Leash agent server wallets) ───────────────────────────────────
MAGIC_OIDC_ISSUER=
MAGIC_OIDC_PROVIDER_ID=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=

# ── Deployment ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=
SESSION_SECRET=
# Server-only, random, and at least 32 bytes.
PAYMENT_INTENT_SIGNING_SECRET=
# Server-only, base64url encoding of exactly 32 random bytes (key version 1).
# Future versions use WEBHOOK_SECRET_ENCRYPTION_KEY_V2, _V3, and so on.
WEBHOOK_SECRET_ENCRYPTION_KEY=

# ── Vercel Blob ───────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ── Scheduler ─────────────────────────────────────────────────────────────────
CRON_SECRET=

# ── CDP (x402 mainnet facilitator) ────────────────────────────────────────────
CDP_API_KEY_NAME=
CDP_API_KEY_PRIVATE_KEY=

# ── Email ─────────────────────────────────────────────────────────────────────
# (Resend or Postmark — resolved in Phase 0 B-07)
EMAIL_API_KEY=
EMAIL_FROM=

# ── Web Push ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Leash demo target (Phase 0 B-10 decision) ─────────────────────────────────
LEASH_DEMO_TARGET_URL=
