{
  "name": "@tab/ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme.css": "./dist/theme.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc --project tsconfig.build.json && cp src/theme.css dist/theme.css",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "node --experimental-strip-types --test src/tokens.test.mjs",
    "lint": "biome check ."
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.2.7",
    "typescript": "^5.8"
  },
  "sideEffects": [
    "**/*.css"
  ]
}
