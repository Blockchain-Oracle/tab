# Tab + Tab — environment variables
# Copy to .env.local (never committed). All values must come from real provisioning (Phase 0).

# ── Particle Universal Accounts ──────────────────────────────────────────────
PARTICLE_PROJECT_ID=
PARTICLE_CLIENT_KEY=
PARTICLE_APP_ID=

# ── Magic ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAGIC_PUBLISHABLE_KEY=
MAGIC_SECRET_KEY=

# ── Magic OIDC (Tab agent server wallets) ───────────────────────────────────
MAGIC_OIDC_ISSUER=
MAGIC_OIDC_PROVIDER_ID=
MAGIC_OIDC_AUDIENCE=
MAGIC_OIDC_KEY_ID=
# Server-only base64 PKCS#8 RSA private key. Never expose or commit a real value.
MAGIC_OIDC_PRIVATE_KEY_B64=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=

# ── Deployment ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=
# Marketing and authenticated-app origins. Required on Vercel preview/production;
# set TAB_DEPLOYMENT_ENV=production to enforce them on another deployment platform.
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_TAB_APP_URL=
TAB_DEPLOYMENT_ENV=
SESSION_SECRET=
# Server-only, random, and at least 32 bytes.
PAYMENT_INTENT_SIGNING_SECRET=
# Server-only, base64url encoding of exactly 32 random bytes (key version 1).
# Future versions use WEBHOOK_SECRET_ENCRYPTION_KEY_V2, _V3, and so on.
WEBHOOK_SECRET_ENCRYPTION_KEY=

# ── Vercel Blob ───────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ── Scheduler ─────────────────────────────────────────────────────────────────
CRON_SECRET=

# ── CDP (x402 mainnet facilitator) ────────────────────────────────────────────
CDP_API_KEY_NAME=
CDP_API_KEY_PRIVATE_KEY=

# ── Email ─────────────────────────────────────────────────────────────────────
# (Resend or Postmark — resolved in Phase 0 B-07)
EMAIL_API_KEY=
EMAIL_FROM=

# ── Web Push ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Tab payment profile + canonical integration target ─────────────────────
# Omit for production mainnet. Set exactly to base_sepolia_integration only for
# the visibly test-labeled Base Sepolia integration deployment.
TAB_AGENT_PROVISIONING_PROFILE=
BASE_SEPOLIA_RPC_URL=
X402_TESTNET_PAYEE_ADDRESS=
# Canonical value is https://<stable-tab-origin>/api/x402/testnet.
TAB_DEMO_TARGET_URL=
# Local integration tests only. Omit in deployed/mainnet environments; setting
# exactly 1 permits loopback payment targets while private/reserved DNS remains blocked.
TAB_ALLOW_DEVELOPMENT_LOOPBACK=

# Testnet faucet (Base Sepolia starter grants — never mainnet)
FAUCET_FUNDER_PRIVATE_KEY=

# Docs app (apps/docs) — domain-agnostic origins for cross-links
# Production: https://app.runtab.xyz / https://docs.runtab.xyz
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
NEXT_PUBLIC_DOCS_ORIGIN=http://localhost:3002
