{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "ARBITRUM_RPC_URL",
        "BASE_RPC_URL",
        "BASE_SEPOLIA_RPC_URL",
        "BLOB_READ_WRITE_TOKEN",
        "CDP_API_KEY_NAME",
        "CDP_API_KEY_PRIVATE_KEY",
        "CRON_SECRET",
        "DATABASE_URL",
        "EMAIL_API_KEY",
        "EMAIL_FROM",
        "LEASH_PROVISIONING_PROFILE",
        "MAGIC_OIDC_AUDIENCE",
        "MAGIC_OIDC_ISSUER",
        "MAGIC_OIDC_KEY_ID",
        "MAGIC_OIDC_PRIVATE_KEY_B64",
        "MAGIC_OIDC_PROVIDER_ID",
        "MAGIC_SECRET_KEY",
        "NEXT_PUBLIC_APP_URL",
        "NEXT_PUBLIC_MAGIC_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_VAPID_PUBLIC_KEY",
        "PARTICLE_APP_ID",
        "PARTICLE_CLIENT_KEY",
        "PARTICLE_PROJECT_ID",
        "PAYMENT_INTENT_SIGNING_SECRET",
        "SESSION_SECRET",
        "TAB_SECRET_KEY",
        "VAPID_PRIVATE_KEY",
        "WEBHOOK_SECRET_ENCRYPTION_KEY",
        "X402_TESTNET_PAYEE_ADDRESS"
      ],
      "outputs": [".next/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "dependsOn": ["^build"],
      "persistent": true,
      "passThroughEnv": ["DATABASE_URL", "PAYMENT_INTENT_SIGNING_SECRET", "SESSION_SECRET"]
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "cache": false,
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "passThroughEnv": ["DATABASE_URL", "PAYMENT_INTENT_SIGNING_SECRET", "SESSION_SECRET"]
    },
    "format": {
      "outputs": []
    }
  }
}
