{
  "name": "@runtab/mcp",
  "version": "0.0.1",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tab-mcp": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./fetch": {
      "types": "./dist/fetch.d.ts",
      "import": "./dist/fetch.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc --build tsconfig.build.json --force",
    "dev": "tsc --watch --preserveWatchOutput --project tsconfig.build.json",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "lint": "biome check .",
    "verify:pack": "node scripts/verify-packed-artifact.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@x402/core": "~2.17.0",
    "@x402/evm": "~2.17.0",
    "@x402/mcp": "~2.17.0",
    "fs-native-extensions": "1.5.0",
    "undici": "7.28.0",
    "viem": "^2.48.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "4.23.1",
    "typescript": "^5.8",
    "vitest": "^4.1.10"
  },
  "description": "Tab MCP proxy: lets an AI agent pay x402 (HTTP 402) charges in USDC under a server-enforced spending cap — the agent never holds a key.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Blockchain-Oracle/tab.git",
    "directory": "apps/agent"
  },
  "keywords": [
    "mcp",
    "x402",
    "ai-agent",
    "payments",
    "usdc",
    "model-context-protocol"
  ],
  "publishConfig": {
    "access": "public"
  }
}
