{
  "name": "@runtab/sdk",
  "version": "0.0.3",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./ua": {
      "types": "./dist/ua.d.ts",
      "import": "./dist/ua.js",
      "require": "./dist/ua.cjs"
    },
    "./showcase": {
      "types": "./dist/showcase.d.ts",
      "import": "./dist/showcase.js",
      "require": "./dist/showcase.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && node scripts/verify-package.mjs",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "lint": "biome check ."
  },
  "peerDependencies": {
    "magic-sdk": ">=33.9.0 <34",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "viem": "^2.48.0"
  },
  "dependencies": {
    "@particle-network/universal-account-sdk": "2.0.3"
  },
  "devDependencies": {
    "magic-sdk": "33.9.0",
    "viem": "^2.48.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "29.1.1",
    "tsup": "8.5.1",
    "typescript": "^5.8",
    "vitest": "^4.1.10"
  },
  "sideEffects": false,
  "description": "Drop-in Tab checkout: <PayButton> pays in USDC from an email login \u2014 no wallet, no cards, no chains visible.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Blockchain-Oracle/tab.git",
    "directory": "packages/sdk"
  },
  "keywords": [
    "payments",
    "checkout",
    "usdc",
    "x402",
    "react",
    "pay-button"
  ]
}
